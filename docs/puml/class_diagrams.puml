title Java Worker Class Diagram



class ScanJob {
    - scanId: UUID
    - domain: String
    - scanTypes: List<TargetType>
    - requestedBy: UUID
    - enqueuedAt: Instant
    --
    + getScanId(): UUID
    + getDomain(): String
    + getScanTypes(): List<TargetType>
    + getRequestedBy(): UUID
    + getEnqueuedAt(): Instant
}

enum TargetType {
    DOMAIN
    REPOSITORY
}

' Scans table (matches ERD)
class ScanEntity {
    - id: UUID
    - userId: UUID
    - idempotencyKey: UUID
    - targetType: String
    - domainId: UUID
    - repoId: Long
    - status: String
    - securityScore: int
    - startedAt: Instant
    - completedAt: Instant
    --
    + getId(): UUID
    + getStatus(): String
    + getSecurityScore(): int
    + setStatus(status: String): void
    + setSecurityScore(score: int): void
    + setCompletedAt(completedAt: Instant): void
}

' Raw data container (in-memory only, not stored in DB)
class ScanResult {
    - scanId: UUID
    - scannerName: String
    - surface: SurfaceType
    - rawData: Map<String, Object>
    - isSuccess: boolean
    - errorMessage: String
    --
    + getRawData(): Map<String, Object>
    + toJson(): String
}

class AggregatedRawData {
    - scanId: UUID
    - domain: String
    - rawResults: List<ScanResult>
    - failures: List<FailureInfo>
    --
    + toJson(): String
    + hasAnySuccess(): boolean
}

class FailureInfo {
    - scannerName: String
    - errorMessage: String
    - failureTime: Instant
}

enum SurfaceType {
    DNS
    SSL
    HTTP_HEADERS
    CT_LOG
    EXPOSURE
    DEPENDENCY
    SAST
    SECRETS
}


' Findings table (matches ERD)
class Finding {
    - id: UUID
    - scanId: UUID
    - surface: SurfaceType
    - severity: Severity
    - title: String
    - cveId: String
    - aiExplanation: String
    - technicalPayload: String
    - remediationSteps: String
    - status: FindingStatus
    --
    + builder(): FindingBuilder
    + getScanId(): UUID
    + getSurface(): SurfaceType
    + getSeverity(): Severity
    + getCveId(): String
    + getAiExplanation(): String
    + getRemediationSteps(): String
}

enum Severity {
    CRITICAL
    HIGH
    MEDIUM
    LOW
}

enum FindingStatus {
    OPEN
    REMEDIATED
    IGNORED
}

' Remediations table (matches ERD)
class Remediation {
    - id: UUID
    - findingId: UUID
    - prNumber: int
    - prUrl: String
    - status: String
    - createdAt: Instant
    --
    + getFindingId(): UUID
    + getPrNumber(): int
    + getPrUrl(): String
    + getStatus(): String
}

' Vulnerability Intel table (matches ERD)
class VulnerabilityIntel {
    - cveId: String
    - repoId: Long
    - description: String
    - cvssScore: BigDecimal
    - hasKnownExploit: boolean
    - affectedPackages: Map<String, String>
    - lastSyncedAt: Instant
    --
    + getCveId(): String
    + getCvssScore(): BigDecimal
    + hasKnownExploit(): boolean
}

class EnrichedScanResult {
    - scanId: UUID
    - securityScore: int
    - findings: List<Finding>
    - processedAt: Instant
}


interface Scanner {
    ..
    + scan(ScanJob request): ScanResult
    + getSupportedTargetType(): TargetType
}

' ----- DOMAIN SCANNERS (5 scanners) -----
class DnsScanner {
    --
    + scan(ScanJob request): ScanResult
    + getSupportedTargetType(): TargetType
}

class SslScanner {
    --
    + scan(ScanJob request): ScanResult
    + getSupportedTargetType(): TargetType
}

class HttpScanner {
    --
    + scan(ScanJob request): ScanResult
    + getSupportedTargetType(): TargetType
}

