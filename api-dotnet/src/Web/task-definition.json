{
  "family": "vulnwatch-task",
  "executionRoleArn": "arn:aws:iam::012834916544:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "vulnwatch-api",
      "image": "012834916544.dkr.ecr.eu-north-1.amazonaws.com/vulnwatch:latest",
      "cpu": 0,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp",
          "name": "vulnwatch-task-80-tcp",
          "appProtocol": "http"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8080/api/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "environment": [
        {
          "name": "ASPNETCORE_ENVIRONMENT",
          "value": "Production"
        },
        {
          "name": "ASPNETCORE_URLS",
          "value": "http://+:8080"
        }
      ],
      "secrets": [
        {
          "name": "ConnectionStrings__DefaultConnection",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/vulnwatch/production/ConnectionStrings__DefaultConnection"
        },
        {
          "name": "Redis__Configuration",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/vulnwatch/production/ConnectionStrings__RedisConnection"
        },
        {
          "name": "Jwt__SecretKey",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/vulnwatch/production/Jwt__SecretKey"
        },
        {
          "name": "GitHub__ClientId",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/vulnwatch/production/GitHub__ClientId"
        },
        {
          "name": "GitHub__ClientSecret",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/vulnwatch/production/GitHub__ClientSecret"
        },
        {
          "name": "Google__ClientId",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/vulnwatch/production/Google__ClientId"
        },
        {
          "name": "Google__ClientSecret",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/vulnwatch/production/Google__ClientSecret"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/vulnwatch-task",
          "awslogs-create-group": "true",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "ulimits": [],
      "systemControls": []
    }
  ]
}